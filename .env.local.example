# Copie este arquivo para .env.local (dev) ou configure como variáveis de
# ambiente reais no servidor/VPS (produção). .env.local NUNCA deve ser
# commitado (já está no .gitignore).

# Segredo usado para assinar os tokens JWT de sessão. Gere um valor
# aleatório forte, por exemplo: openssl rand -base64 48
# Obrigatório em produção — sem isso o servidor recusa iniciar.
JWT_SECRET=

# Connection string do Postgres (Supabase). No painel do Supabase:
# Project Settings > Database > Connection string > URI (modo "Session").
# Formato: postgresql://postgres:[SENHA]@[HOST]:5432/postgres
DATABASE_URL=

# Só defina como "false" se estiver usando um Postgres sem TLS (ex: banco
# local de teste). Contra o Supabase, deixe como está (SSL sempre ligado).
# DATABASE_SSL=false

# Chave da API do Gemini (Google AI Studio) — usada pela Lisa (Orquestrador
# IA). https://aistudio.google.com/apikey
GEMINI_API_KEY=
